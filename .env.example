APP_NAME=AI Planner API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Local Docker Postgres default:
DATABASE_URL=postgresql+psycopg://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
# Supabase examples:
# Direct connection (persistent backend, IPv6 required):
# DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# Session pooler (persistent backend when IPv4 is needed):
# DATABASE_URL=postgresql+psycopg://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DB_CONNECT_TIMEOUT_SECONDS=5
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE_SECONDS=1800
DB_ECHO=false
AUTO_CREATE_TABLES=false
SEED_DEMO_USER=false
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_NAME=Demo User
DEFAULT_DAY_START=06:00
DEFAULT_DAY_END=23:00
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
LLM_MODEL=gemini-2.5-flash-lite
LLM_REASONING_EFFORT=none
LLM_ENABLE_WEB_SEARCH=false
LLM_WEB_SEARCH_DOMAINS=[]
ALLOWED_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]
